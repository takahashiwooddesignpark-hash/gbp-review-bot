# ==============================
# Google Places API
# ==============================
GOOGLE_PLACES_API_KEY=your_places_api_key

# 監視するビジネスのPlace ID
# 調べ方: python list_locations.py を実行
# 対象ビジネス: ウッドデザインパーク岡崎
GOOGLE_PLACE_ID=ChIJ_xxxxxxxxxxxxxxxxxx

# ==============================
# LINE WORKS Bot
# ==============================
LW_CLIENT_ID=your_lineworks_client_id
LW_CLIENT_SECRET=your_lineworks_client_secret
LW_SERVICE_ACCOUNT=your_service_account@your_domain
LW_PRIVATE_KEY_PATH=./lineworks_private_key.pem
LW_BOT_ID=your_bot_id
LW_CHANNEL_ID=your_channel_id

# ==============================
# Bot設定
# ==============================
# チェック間隔（秒）。cronで回す場合は不要
CHECK_INTERVAL_SECONDS=300
